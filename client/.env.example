# Frontend Environment Variables
# Copy to client/.env.local for development

# API URL (for development — in production, same origin serves API)
VITE_API_URL=http://localhost:5000

# Your backend URL (used in production builds)
VITE_BACKEND_URL=https://your-backend.onrender.com

# WebAuthn RP ID (must match WEBAUTHN_RP_ID on backend)
VITE_WEBAUTHN_RP_ID=yourdomain.com
