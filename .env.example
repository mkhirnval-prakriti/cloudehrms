# ═══════════════════════════════════════════════════════════════════════════════
# HRMS Portal — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in values
# 3. NEVER commit .env to GitHub
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Neon (free):    postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
# Supabase (free):postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
# Railway:        postgresql://postgres:pass@containers.railway.app:5432/railway
DATABASE_URL=postgresql://user:password@host:5432/hrmsdb

# Set to 1 for Neon / Supabase (they require SSL)
DB_SSL=1

# ── Super Admin Credentials ───────────────────────────────────────────────────
# Login ID (username) — used on the login page
SUPER_ADMIN_ID=prakritiherbs
# Password — set this ONCE; system stores a secure hash and ignores future changes
# After first login, change password through the Settings panel and REMOVE this var
SUPER_ADMIN_PASSWORD=52265226
# Email for the admin account
SUPER_ADMIN_EMAIL=admin@yourcompany.com

# ── Auth Secrets ──────────────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_SECRET=change-this-to-another-long-random-string-min-48-chars

# ── CORS ─────────────────────────────────────────────────────────────────────
# Your frontend URL(s), comma-separated (add both www and non-www if needed)
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://yourdomain.com
CORS_STRICT=1

# ── WebAuthn (Passkeys / Fingerprint attendance) ──────────────────────────────
# Must exactly match your production hostname (no https://)
WEBAUTHN_RP_ID=yourdomain.com
WEBAUTHN_ORIGINS=https://yourdomain.com
WEBAUTHN_RP_NAME=HRMS Portal
# off | after_register | required
WEBAUTHN_ATTENDANCE=after_register

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Use Gmail App Password (NOT your Gmail login password)
# Setup: Gmail → Account → Security → 2FA ON → App Passwords → Generate
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=HRMS Portal <your-email@gmail.com>
ALERT_EMAIL_TO=admin@yourcompany.com
# Comma-separated emails for daily reports
REPORT_RECIPIENTS=admin@yourcompany.com,hr@yourcompany.com

# ── Company Info ──────────────────────────────────────────────────────────────
COMPANY_EMAIL=contact@yourcompany.com
APP_NAME=HRMS Portal

# ── Google Sheets Sync (Optional) ────────────────────────────────────────────
# Deploy google-apps-script/hrms_sync.gs as a Google Apps Script Web App
GOOGLE_APPS_SCRIPT_WEBAPP_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
# Same secret must be set in Apps Script Properties too
SHEET_SYNC_SECRET=your-random-secret-32-chars

# ── Google OAuth — Sheets Integration (Optional) ─────────────────────────────
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# GOOGLE_OAUTH_REDIRECT_URI=https://yourdomain.com/api/integrations/google/oauth/callback

# ── WhatsApp Notifications (Optional) ────────────────────────────────────────
# Option A — Twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Option B — Meta Cloud API
# WHATSAPP_CLOUD_TOKEN=EAAxxxxxxxxxx
# WHATSAPP_CLOUD_PHONE_NUMBER_ID=xxxxxxxxxx

# Admin WhatsApp numbers (comma-separated, E.164 format: +91XXXXXXXXXX)
# WHATSAPP_ADMIN_NUMBERS=+919876543210
# WHATSAPP_NOTIFY_PUNCH=1
# WHATSAPP_NOTIFY_LEAVE=1

# ── File Storage (Optional — Cloudflare R2) ───────────────────────────────────
# For production file persistence (attendance photos, employee documents)
# Without R2, files are stored locally (lost on Render restart)
# UPLOAD_PROVIDER=r2
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=hrms-uploads
# R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# ── Push Notifications (Optional) ─────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=BExxx...
# VAPID_PRIVATE_KEY=xxx...
# VAPID_SUBJECT=mailto:admin@yourcompany.com

# ── Attendance Settings ────────────────────────────────────────────────────────
FACE_EMBEDDING_MATCH_THRESHOLD=0.55
BIOMETRIC_UPDATE_COOLDOWN_DAYS=14
BIOMETRIC_APPROVAL_WINDOW_HOURS=24

# ── Trash / Soft-delete Retention ─────────────────────────────────────────────
TRASH_RETENTION_MODE=days
TRASH_RETENTION_DAYS=30
TRASH_RETENTION_MINUTES=30
